{
  "db_path": "db/teachers.json",
  "pending_path": "db/pending.json",
  "pending_samples_dir": "pending_samples",
  "teachers_csv": "Teachers.csv",
  "logs_path": "logs/attempts.jsonl",
  "thresholds": {
    "face": 0.30,
    "voice": 0.25,
    "alpha": 0.6,
    "require_both": true,
    "high_confidence_margin": 0.03
},
  "security": {
    "max_audio_seconds": 8.0,
    "max_image_bytes": 4000000,
    "max_audio_bytes": 8000000
  },
  "incremental": {
    "enabled": true,
    "min_fused_for_update": 0.90,
    "min_face_for_update": 0.90,
    "min_voice_for_update": 0.90,
    "max_face_embeddings": 30,
    "max_voice_embeddings": 30,
    "save_samples": true,
    "samples_dir": "samples"
  },
  "admin": {
    "allow_pending_verify": false
  },
  "models": {
    "face": {
      "model_pack": "buffalo_l",
      "use_gpu": false,
      "det_thresh": 0.5,
      "det_size": [640, 640]
    },
    "voice": {
      "device": "cpu",
      "ffmpeg": "ffmpeg"
    }
  },
  "email": {
    "enabled": false
  }
}